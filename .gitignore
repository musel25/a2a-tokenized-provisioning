# --- Python ---
__pycache__/
*.py[cod]
.venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
build/
dist/
*.egg-info/

# --- Foundry / contracts ---
# Ignore forge's generated build output. forge-std is tracked as a git submodule,
# so contracts/lib/ is deliberately NOT ignored.
contracts/cache/
contracts/out/
contracts/broadcast/

# --- Notebooks (the .ipynb is tracked; these are generated caches) ---
.ipynb_checkpoints/
__marimo__/

# --- Environment / local runs ---
.env
.env.local
e2e/runs/

# --- Editor / OS cruft ---
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

# machine-local deploy artifact (regenerate with `just deploy-local`)
deployments/

# containerlab runtime state (root-owned node dirs; the lab is disposable)
netlab/clab-*/
